# Academia Sync - Environment Configuration
# Copy to .env and update values

# LLM Settings
MODEL_NAME=phi3.5:latest
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=thesis_db

# API
API_V1_STR=/api/v1

# Data
THESIS_DATA_PATH=../data/thesis.xlsx
